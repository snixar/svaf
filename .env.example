# GitHub repository for online article publishing (/write page)
# Fill these in Cloudflare Pages Dashboard → Settings → Environment variables
PUBLIC_GITHUB_OWNER=your-github-username
PUBLIC_GITHUB_REPO=your-blog-repo-name
PUBLIC_GITHUB_BRANCH=main

# Umami Analytics (https://umami.is)
# For self-hosted Umami, change PUBLIC_UMAMI_SRC to your own instance URL
PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js
PUBLIC_UMAMI_WEBSITE_ID=your-website-id
